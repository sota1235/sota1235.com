---
import Layout from '../../layouts/Layout.astro'
import PageHeaderText from '../../components/PageHeaderText.astro'
import { getCollection } from 'astro:content'
import MediaListItem from '../../components/MediaListItem.astro'

const slides = (await getCollection('slides')).sort(
  (a, b) => Date.parse(b.data.date) - Date.parse(a.data.date)
)
---

<Layout title="SLIDES" description="All slides of @sota1235">
  <PageHeaderText>SLIDES</PageHeaderText>
  <div class="mb-[200px]">
    {
      slides.map((item) => (
        <MediaListItem
          title={item.data.title}
          mediaTitle={item.data.mediaTitle}
          imageUrl={item.data.ogpImageUrl}
          link={item.data.link}
        />
      ))
    }
  </div>
</Layout>
